    "cloudSave": "\u0425\u043c\u0430\u0440\u043d\u0435 \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f",
    "cloudSaveInfo": "\u041d\u0430\u0442\u0438\u0441\u043d\u0443\u0432\u0448\u0438 \"\u041a\u043e\u043f\u0456\u044e\u0432\u0430\u0442\u0438 URL \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f\", \u043c\u043e\u0436\u043d\u0430 \u043f\u043e\u043a\u0430\u0437\u0430\u0442\u0438 \u0439 \u0441\u043a\u043e\u043f\u0456\u044e\u0432\u0430\u0442\u0438 URL \u0434\u043b\u044f \u0433\u043b\u043e\u0431\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f \u043f\u043e\u0442\u043e\u0447\u043d\u0438\u0445 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u044c.\n\u0412\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0438 \u0441\u043a\u043e\u043f\u0456\u0439\u043e\u0432\u0430\u043d\u0438\u0439 URL \u0443 \"\u0412\u0441\u0442\u0430\u0432\u0438\u0442\u0438 \u0441\u043a\u043e\u043f\u0456\u0439\u043e\u0432\u0430\u043d\u0438\u0439 URL\", \u043c\u043e\u0436\u043d\u0430 \u0437\u0431\u0435\u0440\u0435\u0433\u0442\u0438 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f.",
    "saveUrlCopy": "\u041a\u043e\u043f\u0456\u044e\u0432\u0430\u0442\u0438 URL \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f",
    "pasteSaveUrl": "\u0412\u0441\u0442\u0430\u0432\u0438\u0442\u0438 \u0441\u043a\u043e\u043f\u0456\u0439\u043e\u0432\u0430\u043d\u0438\u0439 URL\n(\u0417\u0431\u0435\u0440\u0435\u0433\u0442\u0438)",
    "aboutCloudSaveTitle": "\u041f\u0440\u043e \u0445\u043c\u0430\u0440\u043d\u0435 \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f",
    "aboutCloudSaveDescription": "\u0425\u043c\u0430\u0440\u043d\u0435 \u0437\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u043d\u044f \u0434\u043e\u0437\u0432\u043e\u043b\u044f\u0454 \u0437\u0431\u0435\u0440\u0435\u0433\u0442\u0438 \u043f\u043e\u0442\u043e\u0447\u043d\u0456 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u043c\u0456\u0436 \u0441\u0432\u0456\u0442\u0430\u043c\u0438, \u0449\u043e\u0431 \u043d\u0435 \u043d\u0430\u043b\u0430\u0448\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0457\u0445 \u0437\u0430\u043d\u043e\u0432\u043e.\n\u0417\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u0456 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u044e\u0442\u044c\u0441\u044f \u043f\u0440\u0438 \u0432\u0445\u043e\u0434\u0456 \u0432 \u0431\u0443\u0434\u044c-\u044f\u043a\u0438\u0439 \u0441\u0432\u0456\u0442, \u0434\u0435 \u0432\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043e \u0446\u0435 \u043c\u0435\u043d\u044e.\n(\u041f\u043e\u0442\u0440\u0456\u0431\u043d\u043e \u0443\u0432\u0456\u043c\u043a\u043d\u0443\u0442\u0438 \"Allow Untrusted URLs\" \u0443 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f\u0445 VRChat \u0432 \u0440\u043e\u0437\u0434\u0456\u043b\u0456 \"Comfort & Safety\")\n\u042f\u043a\u0449\u043e \u0456\u043a\u043e\u043d\u043a\u0430 \u0445\u043c\u0430\u0440\u0438 \u0443 \u0432\u0435\u0440\u0445\u043d\u044c\u043e\u043c\u0443 \u043f\u0440\u0430\u0432\u043e\u043c\u0443 \u043a\u0443\u0442\u0456 \u043c\u0435\u043d\u044e \u0437\u0435\u043b\u0435\u043d\u0430, \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043e \u0437 \u0445\u043c\u0430\u0440\u0438; \u044f\u043a\u0449\u043e \u0436\u043e\u0432\u0442\u0430, \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043e \u0437 Persistence.",
